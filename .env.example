# Copie este arquivo para .env e preencha com os valores reais
# cp .env.example .env

# ── Supabase (React frontend) ─────────────────────────────────────────
# Encontre em: https://supabase.com → seu projeto → Settings → API
REACT_APP_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
REACT_APP_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Banco de dados local SQLite ───────────────────────────────────────
DB_PATH=efetivo.db

# SQL Server TOTVS
SQL_SERVER=000.000.000.000
SQL_PORT=15000
SQL_DATABASE=NOME_DO_BANCO
SQL_USER=seu_usuario
SQL_PASSWORD=sua_senha

# Flask (gere uma chave com: python -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET_KEY=troque-por-uma-chave-aleatoria-longa
