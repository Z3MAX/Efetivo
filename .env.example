# Copie para .env e preencha com os valores reais
# cp .env.example .env

# ── Neon DB (backend + init_neon.py) ─────────────────────────────────
# Encontre em: https://console.neon.tech → seu projeto → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── JWT (Netlify Function) ────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=troque-por-uma-chave-aleatoria-longa

# ── SQL Server TOTVS (sync_ponto.py) ─────────────────────────────────
SQL_SERVER=000.000.000.000
SQL_PORT=15000
SQL_DATABASE=NOME_DO_BANCO
SQL_USER=seu_usuario
SQL_PASSWORD=sua_senha
